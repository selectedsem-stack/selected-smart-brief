# Flask
SECRET_KEY=change-me-to-random-32-chars
BASE_URL=http://localhost:5000
FLASK_DEBUG=1

# Anthropic (Sprint 4 — leave empty for now, app runs without AI in degraded mode)
ANTHROPIC_API_KEY=

# Email (Sprint 5 — pick one provider, leave others empty)
# Option A: Gmail SMTP with App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Option B: Resend
RESEND_API_KEY=

# Manager destination
MANAGER_EMAIL=

# Brief template defaults
DEFAULT_TEMPLATE=seo-ppc-brief

# HTTP Basic Auth gate (set ACCESS_PASSWORD on Render to enable; leave empty locally)
ACCESS_USER=selected
ACCESS_PASSWORD=
