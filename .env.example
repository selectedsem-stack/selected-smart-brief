# Flask
SECRET_KEY=change-me-to-random-32-chars
BASE_URL=http://localhost:5000
FLASK_DEBUG=1

# Anthropic (Sprint 4 — leave empty for now, app runs without AI in degraded mode)
ANTHROPIC_API_KEY=

# Email (Resend — free tier 3000/month)
# Sign up at https://resend.com → API Keys → Create
RESEND_API_KEY=
# Sender address. Default: onboarding@resend.dev (test sender, no DNS needed).
# For production: brief@selected.co.il (requires DNS verification on Resend dashboard).
RESEND_FROM_EMAIL=onboarding@resend.dev

# Manager destination — receives the approval-link email
MANAGER_EMAIL=

# Brief template defaults
DEFAULT_TEMPLATE=seo-ppc-brief

# HTTP Basic Auth gate (set ACCESS_PASSWORD on Render to enable; leave empty locally)
ACCESS_USER=selected
ACCESS_PASSWORD=
